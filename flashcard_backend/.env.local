# ── Local development environment ────────────────────────────────────────────
# Matches the MySQL container started by docker-compose.yml in the project root.
# Usage:
#   cp .env.local .env
#   docker-compose up -d   (start MySQL)
#   uvicorn app.main:app --reload
# ─────────────────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=3306
DB_NAME=flashcard_db
DB_USER=flashcard_user
DB_PASSWORD=flashcard_pass
